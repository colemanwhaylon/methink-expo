{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "expo export -p web",
  "outputDirectory": "dist",
  "devCommand": "expo start --web",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/scripture/:dataset/:book", "destination": "/scripture/[dataset]/[book]" },
    { "source": "/scripture/:dataset", "destination": "/scripture/[dataset]" },
    { "source": "/docs/:index", "destination": "/docs/[index]" },
    { "source": "/catalog/:index", "destination": "/catalog/[index]" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
